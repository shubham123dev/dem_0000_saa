{
  "name": "dbmr-workplace-agent-frontend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "build": "npm run build:library && npm run build:showcase",
    "build:library": "ng build workplace-agent --configuration production",
    "build:showcase": "ng build workplace-agent-showcase --configuration production",
    "start": "npm run build:library && ng serve workplace-agent-showcase --proxy-config proxy.conf.json",
    "start:showcase": "ng serve workplace-agent-showcase --proxy-config proxy.conf.json",
    "watch:library": "ng build workplace-agent --configuration development --watch",
    "test": "ng test workplace-agent-showcase --watch=false"
  },
  "dependencies": {
    "@angular/cdk": "22.0.4",
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/forms": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@angular/router": "22.0.6",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular/build": "22.0.6",
    "@angular/cli": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "ng-packagr": "22.0.1",
    "typescript": "6.0.2"
  },
  "engines": {
    "node": ">=22.22.3 <23 || >=24.15.0 <25 || >=26.0.0"
  }
}
