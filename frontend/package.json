{
  "name": "dbmr-workplace-agent-ui",
  "version": "0.1.0",
  "private": true,
  "description": "Angular presentation layer for the governed DBMR Workplace Agent sandbox",
  "engines": {
    "node": "^20.19.0 || ^22.12.0 || ^24.0.0",
    "npm": ">=10"
  },
  "scripts": {
    "start": "ng serve --host 127.0.0.1 --port 4200",
    "build": "ng build",
    "build:development": "ng build --configuration development",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.spec.json --noEmit && tsc -p tsconfig.e2e.json --noEmit",
    "lint": "eslint \"src/**/*.ts\" \"src/**/*.html\" \"e2e/**/*.ts\"",
    "test": "ng test --watch=false",
    "test:coverage": "ng test --watch=false --coverage",
    "e2e": "playwright test",
    "e2e:list": "playwright test --list",
    "quality:boundaries": "node scripts/check-architecture-boundaries.mjs",
    "validate:phase1": "npm run quality:boundaries && npm run typecheck && npm run lint && npm run test && npm run build && npm run e2e:list",
    "validate:full": "npm run validate:phase1 && npm run e2e"
  },
  "dependencies": {
    "@angular/cdk": "21.2.14",
    "@angular/common": "21.2.18",
    "@angular/compiler": "21.2.18",
    "@angular/core": "21.2.18",
    "@angular/forms": "21.2.18",
    "@angular/platform-browser": "21.2.18",
    "@angular/router": "21.2.18",
    "rxjs": "7.8.2",
    "tslib": "2.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@angular/build": "21.2.18",
    "@angular/cli": "21.2.18",
    "@angular/compiler-cli": "21.2.18",
    "@eslint/js": "9.39.1",
    "@playwright/test": "1.61.1",
    "@types/node": "24.3.0",
    "angular-eslint": "21.2.0",
    "eslint": "9.39.1",
    "jsdom": "27.0.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.46.2",
    "vitest": "4.1.10"
  }
}
