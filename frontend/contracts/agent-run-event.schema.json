{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://dbmr.example/contracts/agent-run-event.schema.json",
  "title": "Safe agent run event",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "sequence",
    "type",
    "stage",
    "message",
    "payload",
    "terminal",
    "occurred_at"
  ],
  "properties": {
    "schema_version": { "const": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "sequence": { "type": "integer", "minimum": 1 },
    "type": {
      "enum": [
        "run.accepted",
        "run.started",
        "activity.updated",
        "clarification.required",
        "proposal.created",
        "answer.completed",
        "run.cancel_requested",
        "run.cancelled",
        "run.failed"
      ]
    },
    "stage": {
      "enum": [
        "request_acceptance",
        "access_check",
        "request_planning",
        "data_retrieval",
        "proposal_preparation",
        "answer_preparation",
        "external_wait",
        "verification",
        "completion"
      ]
    },
    "message": { "type": "string", "minLength": 1, "maxLength": 240 },
    "payload": { "type": ["object", "null"] },
    "terminal": { "type": "boolean" },
    "occurred_at": { "type": "string", "format": "date-time" }
  }
}
