# DBMR Workplace Agent - Step 0 environment configuration example
#
# Copy this file to `.env` and adjust locally. Never commit a real `.env`.
# No secrets, credentials, or personal information may be committed.

# Async SQLAlchemy database URL for the mock sandbox database.
WORKPLACE_DATABASE_URL=sqlite+aiosqlite:///./workplace_sandbox.db

# The only environment supported in Step 0 is "sandbox".
WORKPLACE_ENVIRONMENT=sandbox

# API metadata
WORKPLACE_APP_NAME=DBMR Workplace Agent (Sandbox)
