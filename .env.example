WORKPLACE_DATABASE_URL=sqlite+aiosqlite:///./workplace_sandbox.db
WORKPLACE_ENVIRONMENT=sandbox
WORKPLACE_APP_NAME=DBMR Workplace Agent (Sandbox)
WORKPLACE_ENABLE_RAW_MOCK_API=false

WORKPLACE_AGENT_MODEL_PROVIDER=
WORKPLACE_AGENT_MODEL_API_KEY=
WORKPLACE_AGENT_MODEL_NAME=gpt-5-mini
WORKPLACE_AGENT_MODEL_ENDPOINT=https://api.openai.com/v1/responses
WORKPLACE_AGENT_MODEL_TIMEOUT_SECONDS=20
WORKPLACE_AGENT_MODEL_MAXIMUM_ATTEMPTS=2
WORKPLACE_AGENT_MODEL_RETRY_DELAY_SECONDS=0.25
WORKPLACE_AGENT_MODEL_MAXIMUM_OUTPUT_TOKENS=1000
