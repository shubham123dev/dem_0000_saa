# DBMR Workplace Agent - Step 0 environment configuration example
# Copy to `.env`. Never commit real credentials or personal information.

WORKPLACE_DATABASE_URL=sqlite+aiosqlite:///./workplace_sandbox.db
WORKPLACE_ENVIRONMENT=sandbox
WORKPLACE_APP_NAME=DBMR Workplace Agent (Sandbox)

# Local-only raw mock Nucleus API. Keep false outside isolated sandbox testing.
WORKPLACE_ENABLE_RAW_MOCK_API=true
